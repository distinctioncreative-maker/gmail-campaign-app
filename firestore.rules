rules_version = '2';

// Defense-in-depth: the app's server routes are the primary access path
// (Admin SDK bypasses these rules). These rules exist so that any direct
// client SDK access can never cross user or organization boundaries.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // A user's own profile document (no role/org escalation from client).
    match /users/{userId} {
      allow read: if isSelf(userId);
      allow write: if false; // server-only

      // Sensitive: encrypted Gmail tokens — never client-readable.
      match /gmailConnections/{connectionId} {
        allow read, write: if false;
      }

      // Queue internals are server-only.
      match /campaigns/{campaignId}/queue/{queueItemId} {
        allow read, write: if false;
      }

      // All other user-owned data: readable only by that user.
      // Mutations go through authenticated server routes.
      match /{collection}/{docId} {
        allow read: if isSelf(userId);
        allow write: if false;
      }

      match /campaigns/{campaignId}/{sub}/{docId} {
        allow read: if isSelf(userId)
          && sub != 'queue';
        allow write: if false;
      }
    }

    match /organizations/{orgId} {
      // Membership check reads own member doc only.
      match /members/{userId} {
        allow read: if isSelf(userId);
        allow write: if false;
      }

      // Collision hashes and org settings are server-only.
      match /teamCollisionHashes/{hash} {
        allow read, write: if false;
      }
      match /organizationSettings/{docId} {
        allow read, write: if false;
      }
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
