# ── Google Cloud ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_REGION=us-central1
FIREBASE_PROJECT_ID=

# ── OAuth (Gmail connect flow — separate from app sign-in) ────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Comma-separated Google Workspace domain allowlist for app sign-in.
# Each domain becomes its OWN isolated organization (separate admin, team,
# and settings). The FIRST domain listed is the "primary" tenant and maps to
# the existing default org — keep it first so nothing migrates. Example:
#   alpinefundings.com,everestbusinessfunding.com
ALLOWED_GOOGLE_WORKSPACE_DOMAIN=

# 32+ char random string; used for session cookie signing
SESSION_SECRET=

# ── Token encryption ──────────────────────────────────────────
# Full KMS key resource name:
# projects/PROJECT/locations/LOC/keyRings/RING/cryptoKeys/KEY
TOKEN_KMS_KEY_RESOURCE=
# Local development ONLY: base64 32-byte AES key used when
# TOKEN_KMS_KEY_RESOURCE is unset. Never set in production.
LOCAL_DEV_ENCRYPTION_KEY=

# ── Cloud Tasks ───────────────────────────────────────────────
CLOUD_TASKS_QUEUE=campaign-sends
CLOUD_TASKS_SERVICE_ACCOUNT=
CLOUD_TASKS_WORKER_AUDIENCE=

# ── App ───────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
DEFAULT_ORGANIZATION_NAME=
DEFAULT_COMPANY_NAME=
DEFAULT_COMPANY_WEBSITE=
DEFAULT_PHYSICAL_ADDRESS=

# ── Email safety ──────────────────────────────────────────────
# Sending mode is controlled IN-APP by an admin (Administration →
# Sending mode), defaulting to TEST. In test mode every outbound email is
# redirected to TEST_EMAIL_DESTINATION with a [TEST] subject.
TEST_EMAIL_DESTINATION=
# Optional deployment lock: set to "true" on staging to force test mode and
# DISABLE the in-app live switch. Leave empty in production so the admin
# controls sending from the app. (Legacy TEST_MODE=true still acts as a lock.)
FORCE_TEST_MODE=

# ── Firebase web SDK (client, public) ─────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_ALLOWED_DOMAIN=
